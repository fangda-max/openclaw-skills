{
  "base_path": "${WORKSPACE_DATA_DIR}",
  "llm": {
    "provider": "minimax",
    "api_key": "${API_KEY}",
    "api_url": "https://api.minimaxi.com/v1/text/chatcompletion_v2",
    "model": "MiniMax-M2.7",
    "temperature": 0.1,
    "max_tokens": 500
  },
  "output_file": "${base_path}/keywords.json"
}
