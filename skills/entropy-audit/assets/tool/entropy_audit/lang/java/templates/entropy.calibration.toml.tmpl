# =========================
# 校准元信息
# 记录这份校准文件是谁生成、何时生成、为什么生成
# =========================
[meta]
# 生成者；填写这份校准文件的责任人或生成工具名。
# init 默认填入 entropy-audit init，后续可按实际责任人修改。
author = {{CALIBRATION_AUTHOR}}
# 生成时间；建议保留这次校准正式生效的时间点。
# init 在初始化时自动填入当前时间。
generated_at = {{CALIBRATION_GENERATED_AT}}
# 校准原因；建议写成稳定短语，便于后续按周期筛选。
# 常见值：bootstrap / baseline / monthly-review / quarterly-review / hotfix-review。
reason = {{CALIBRATION_REASON}}


# =========================
# 人工排除项
# 用于声明本期需要人工说明的例外，不直接改主规则
# =========================
[exclusions]
# 因紧急修复、线上止血、监管应急等场景带来的临时变更单元。
# 适用场景：本期为了先恢复可用性，临时引入了额外类、方法、分支或补丁目录，这些改动短期内会拉高熵，但已经明确会在后续窗口回收。
# 填写建议：写变更单号、模块名、类名、目录路径或 hotfix 标识，保证后面能追溯。
# 不适用：常规需求开发、长期保留的架构改动，不要放这里规避评分。
hotfix_change_units = []
# 本期临时排除的校验目标名称，需和 [commands] / [scope].validation_targets 中的别名一致。
# 适用场景：校验脚本正在迁移、CI 环境故障、外部依赖平台不可用、某项检查尚未接通但已确认是短期问题。
# 填写建议：这里只填目标别名，例如 build / test / smoke；具体原因写在本期治理记录或评审结论里。
# 不适用：某项校验长期没有建设好，不应长期挂在这里，应回到主配置或治理计划里补齐。
temporarily_excluded_validations = []
# 已确认待归档、待合并、待补齐，但本期先豁免的文档路径。
# 适用场景：旧文档即将归档、新文档已在补写、目录正在搬迁，导致这期文档覆盖指标会暂时失真。
# 填写建议：写仓库内相对路径，最好只填已经识别出替代方案或归档计划的文档。
# 不适用：本来就缺文档、但还没有治理计划的情况；那属于真实治理缺口，不应放这里隐藏。
pending_archive_docs = []


# =========================
# 人工门禁标志
# 用于评分器 gates 的 manual_flag 条件
# 可继续扩展自定义布尔标志，但值必须是 true/false
# =========================
[flags]
# 权限门禁是否通过；用于识别当前团队是否具备推进治理动作的必要权限。
# 典型判断：是否能改 CI、是否能改核心模块、是否能申请库表/配置/平台权限。
permission_gate_pass = false
# 事实源门禁是否通过；用于识别 source of truth 是否已明确。
# 典型判断：术语口径、主数据来源、接口契约、模块归属、架构基线是否已经被确认。
source_of_truth_gate_pass = false
