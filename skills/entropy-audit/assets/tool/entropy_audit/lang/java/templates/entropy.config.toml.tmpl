[code_entropy.weights]
# 结构熵权重。
structure_entropy = 0.30
# 语义熵权重。
semantic_entropy = 0.25
# 行为熵权重。
behavior_entropy = 0.20
# 认知熵权重。
cognition_entropy = 0.15
# 风格熵权重。
style_entropy = 0.10


# =========================
# 汇总分公式模型
# 用于把五类熵聚合成总熵，并派生健康度
# =========================
[code_entropy.score_models.health]
# 总熵 / 派生健康度公式版本；只要 weights 或 health 聚合参数变化，就必须同步升级。
formula_version = "total-entropy-derived-health-v1"
# 聚合方式；当前支持 weighted_average。
aggregation = "weighted_average"
# 是否把总熵按“100 - 总熵”反向派生成健康度。
invert_scores = true
# 单个熵分的量纲上限；当前五类熵统一都是 0~100。
entropy_score_scale = 100.0
# 总熵与派生健康度输出量纲上限；当前统一为 0~100。
output_scale = 100.0
# 是否先按权重做归一化平均，再映射到输出量纲。
normalize_weights = true
# 健康度保留的小数位数。
round_digits = 1


# =========================
# 趋势治理进度模型
# 用于把 capability / risk / health 的变化聚合成治理进度
# =========================
[code_entropy.trend_models.governance_progress]
# 治理进度公式版本；只要 basis_priority / status_thresholds / component_weights / components.* 变化，就必须同步升级。
formula_version = "governance-progress-v1"
# 优先使用哪种对比基准来计算治理进度。
basis_priority = ["baseline", "prev"]
# 组件归一化后的目标量纲；当前统一为百分制。
value_scale = 100.0
# 治理进度保留的小数位数。
round_digits = 1

[code_entropy.trend_models.governance_progress.status_thresholds]
# 达到该值及以上，判定为持续改善。
improving = 3.0
# 达到该值及以下，判定为出现回退。
regressing = -3.0

[code_entropy.trend_models.governance_progress.component_weights]
# 能力指数变化在治理进度中的权重。
capability_gain = 1.0
# 风险指数变化在治理进度中的权重。
risk_reduction = 1.0
# 健康度变化在治理进度中的权重。
health_gain = 1.0

[code_entropy.trend_models.governance_progress.components.capability_gain]
# 是否启用能力增益组件。
enabled = true
# 从 delta_* 中读取哪个字段。
delta_field = "capability_index"
# 该字段的量纲上限；当前能力指数为 0~5。
delta_scale = 5.0
# 是否在计算前反转符号。
invert = false

[code_entropy.trend_models.governance_progress.components.risk_reduction]
# 是否启用风险收敛组件。
enabled = true
# 从 delta_* 中读取哪个字段。
delta_field = "risk_index"
# 该字段的量纲上限；当前风险指数为 0~5。
delta_scale = 5.0
# 风险下降代表改善，因此这里需要反转符号。
invert = true

[code_entropy.trend_models.governance_progress.components.health_gain]
# 是否启用健康度变化组件。
enabled = true
# 从 delta_* 中读取哪个字段。
delta_field = "health_score"
# 健康度量纲上限；当前是 0~100。
delta_scale = 100.0
# 健康度升高代表改善，因此不反转。
invert = false


