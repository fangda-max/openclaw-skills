# =========================
# Java 结构熵检测器：共享承载目录识别
# =========================
[code_entropy.java.detectors]

[code_entropy.java.detectors.structure]

[code_entropy.java.detectors.structure.shared_buckets]
# 路径命中模式：segment 表示按目录段精确匹配；contains 表示路径中包含关键字就算。
match_mode = "segment"
# 共享承载目录别名列表，例如 common / commons。
shared_aliases = ["common", "commons"]
# 工具目录别名列表，例如 util / utils。
utility_aliases = ["util", "utils"]
# 共享承载目录路径前缀列表；相对 project.root 配置。
# 适合项目里已经明确约定公共包路径时使用，留空表示不启用前缀强约束。
shared_path_prefixes = []
# 工具目录路径前缀列表；相对 project.root 配置。
utility_path_prefixes = []


# =========================
# Java 结构熵检测器：目录分布
# =========================
[code_entropy.java.detectors.structure.directory_distribution]
# 一个目录中 Java 文件达到多少时，判为“超大目录”。
oversized_dir_file_threshold = 20
# 前多少个最大目录参与“前 N 大目录集中度”计算。
top_n_concentration_count = 5


# =========================
# Java 语义熵检测器：术语抽取 / 状态定义重复
# =========================
[code_entropy.java.detectors.semantic]

[code_entropy.java.detectors.semantic.term_extraction]
# scan_targets 控制从文件名、类名还是两者提取术语。
# Java 项目默认建议只统计 class_name，避免 file_stem 与类名重复计数。
scan_targets = ["class_name"]
token_patterns = ["[A-Z][a-z0-9]+"]
# naming_ignore_class_suffixes 用来给 suffix 家族降噪，例如 Job / Task / Work。
# 只有命名概念冲突在做 suffix 匹配时才会忽略这些包装类后缀，不影响前缀家族。
naming_ignore_class_suffixes = ["DTO", "VO", "DO", "Req", "Resp", "Request", "Response"]

[code_entropy.java.detectors.semantic.state_detection]
# 状态定义重复检测：先找“状态承载体”，再抽“状态项”，最后按重合度聚成重复簇。
# carrier_name_patterns：哪些类名 / 枚举名会被当成状态承载体，例如 XxxStatus / XxxState。
carrier_name_patterns = ["(?:^|.*)(?:Status|State)(?:.*|$)"]
# constant_field_pattern：在 class 型状态承载体里，提取 public static final 常量名与右值。
constant_field_pattern = "\\b(?:(?:public|protected|private|static|final|transient|volatile)\\s+){1,8}[A-Za-z_][\\w<>\\[\\].?]*\\s+([A-Z][A-Z0-9_]{2,})\\s*=\\s*([^;]+);"
# string_literal_pattern / numeric_literal_pattern：当常量名不足以表达状态项时，用右值补充归一化。
string_literal_pattern = "\"([A-Za-z][A-Za-z0-9_:-]*)\""
numeric_literal_pattern = "\\b(\\d+)\\b"
# strip_prefixes / strip_suffixes：归一化状态项时去掉的通用前后缀。
strip_prefixes = ["STATUS_", "STATE_"]
strip_suffixes = ["_STATUS", "_STATE", "_CODE", "_VALUE"]
# ignore_item_patterns：归一化后直接忽略的状态项模式。
# 这里先压掉 CD_1 / CD_2 / ... 这类模板编码，避免它们被误当成真实业务状态重复。
ignore_item_patterns = ["^CD_\\d+$"]
# min_carrier_items：一个状态载体至少抽到多少个状态项，才纳入统计。
min_carrier_items = 2
# min_shared_items：两个状态载体至少共享多少个状态项，才有资格判重。
min_shared_items = 2
# similarity_threshold：重复判定阈值，当前使用 overlap coefficient = shared / min(len(a), len(b))。
similarity_threshold = 0.8
# cluster_sample_limit：详情页最多展示多少组重复簇与每簇样例。
cluster_sample_limit = 10

# scatter_sample_limit：状态值散落详情最多展示多少个状态值与样例位置。
scatter_sample_limit = 20

# hardcoded_context_patterns：命中这些上下文字段名的字符串字面量，会按状态值散落候选统计。
hardcoded_context_patterns = ["(?i)\\b(?:status|state|statusCd|statusCode|stateCd|stateCode)\\b"]


# =========================
# Java 行为熵检测器
# =========================
[code_entropy.java.detectors.behavior]

[code_entropy.java.detectors.behavior.error_patterns]
# 错误处理模式识别正则。
throw_exception = "throw\\s+new\\s+\\w+Exception"
return_null = "return\\s+null"
return_error_code = "return\\s+(-?\\d+|ERROR_\\w+)"
try_catch = "try\\s*\\{[\\s\\S]*?\\}\\s*catch"
log_error = "log\\.(error|warn|debug)\\s*\\("

[code_entropy.java.detectors.behavior.return_patterns]
# 返回模式识别正则。
string_literal_pattern = "return\\s+\"[^\"]*\""
boolean_literal_pattern = "return\\s+(?:true|false)\\b"
null_return_pattern = "return\\s+null\\b"
named_reference_pattern = "return\\s+[A-Za-z_]\\w*\\s*;"
exception_pattern = "throw\\s+new\\s+(\\w+Exception)"

[code_entropy.java.detectors.behavior.wrapped_error_responses]
# 错误包装返回的静态工厂方法名。
method_names = ["error", "fail", "failure", "failed", "badRequest", "serverError", "forbidden", "unauthorized"]
include_return_only = true

[code_entropy.java.detectors.behavior.business_exceptions]
# 行为熵“业务异常未收敛”使用的标准业务异常集合。
standard_types = ["BusinessException"]
name_patterns = ["BusinessException$", "BizException$", "ServiceException$"]


