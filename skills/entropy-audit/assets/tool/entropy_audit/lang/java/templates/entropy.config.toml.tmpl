# =========================
# 项目基础信息
# =========================
[project]
# 项目标识，要求全局稳定，历史趋势对比会依赖它关联同一个项目。
id = {{PROJECT_ID}}
# 项目展示名称，用于报告、Dashboard 等界面展示。
name = {{PROJECT_NAME}}
# 项目语言；Java init 固定生成 java。
language = "java"


# =========================
# 治理范围定义
# =========================
[scope]
# 关键流程标识列表，用于告诉熵治理系统哪些业务流程最重要。
critical_flows = {{CRITICAL_FLOWS}}
# 需要关注的校验目标名称列表，对应 [commands] 里的命令别名。
validation_targets = ["build", "test"]
# 需要长期守住的架构/工程不变量名称列表，对应 [commands] 里的检查别名。
required_invariants = []


# =========================
# 文档路径配置
# =========================
[paths]
# 架构文档、设计说明、快速入门等路径，用于支撑“治理支撑度”相关指标。
architecture = {{ARCHITECTURE_PATHS}}
# 运维手册、启动说明、部署说明等路径。
runbooks = {{RUNBOOK_PATHS}}
# 计划、治理方案、执行计划等路径。
plans = {{PLAN_PATHS}}


# =========================
# 外部数据源导入
# =========================
[sources]
# PR 导出文件路径；为空表示当前未接入。
pr_export = ""
# CI 导出文件路径；为空表示当前未接入。
ci_export = ""
# 缺陷/任务系统导出文件路径；为空表示当前未接入。
issue_export = ""
# Agent 日志导出路径；为空表示当前未接入。
agent_logs = ""
# 外部 code entropy 导出路径；为空表示使用内置 Java analyzer。
code_entropy_export = ""


# =========================
# 代码本体熵总开关
# =========================
[code_entropy]
# 是否启用代码本体熵分析。
enabled = true
# 扫描时要排除的目录名列表。
exclude_dirs = {{EXCLUDE_DIRS}}
# 参与扫描的文件扩展名列表。
# 当前内置 Java analyzer 只支持 .java；其他语言后续会走各自的 lang adapter。
include_extensions = [".java"]
# 识别项目内部包前缀，用于区分内部代码与外部依赖或通用内容。
internal_package_prefixes = {{INTERNAL_PACKAGE_PREFIXES}}

# 五类熵评分配置现在只保留 V1 主评分卡。
# 五个 analyzer 的指标公式、规则、权重、阈值统一从 [code_entropy.scoring_v1] 读取。


# =========================
# Code Entropy Scoring V1
# 固定分母评分卡，作为五大熵主评分口径
# =========================
# ============================================
# Code Entropy Scoring V1 配置
# 目标：
# 1. 解决 V1 按 available_weight 动态归一化导致的分母漂移
# 2. 把“事实值 / 归一化指标 / 规则风险分 / 维度总分”分层
# 3. 五类熵统一迁入同一套固定分母评分卡
# ============================================

[code_entropy.scoring_v1]
# 是否启用 V1 评分引擎。
enabled = true
# 当前 schema 版本，仅用于配置演进与排错。
schema_version = "code-entropy-scoring-v1-draft1"
# 当前 V1 聚合总版本。
# 只要五类熵任一 metric / rule / band / weight / level_bands / defaults 发生变化，
# 或者会影响五类熵 raw facts 的 strategy / detectors / switches 发生变化，
# 就必须同步升级这个版本号。
formula_version = "java-code-entropy-scorecard-v1-p8"
# 当前已经迁入 V1 的维度。
migrated_dimensions = ["structure", "semantic", "behavior", "cognition", "style"]

[code_entropy.scoring_v1.defaults]
# V1 内部统一用 0-100 风险分聚合。
internal_scale = 100.0
# 对外页面统一展示 0-100 熵分。
display_scale = 100.0
# 页面分数保留位数。
display_round_digits = 1
# coverage 保留位数。
coverage_round_digits = 3
# 熵分语义：higher_is_worse 表示数值越高风险越大。
score_direction = "higher_is_worse"
# 固定评分卡加权平均：总分只除以 scorecard 固定总权重，不再除以 available_weight。
aggregation = "fixed_weighted_average"

[code_entropy.scoring_v1.dimensions.structure]
label = "结构熵"
enabled = true
formula_version = "java-structure-scorecard-v1-p3"
internal_scale = 100.0
display_scale = 100.0
display_round_digits = 1
coverage_round_digits = 3
score_direction = "higher_is_worse"
aggregation = "fixed_weighted_average"

[code_entropy.scoring_v1.dimensions.structure.level_bands]
# 这里是 0-100 风险分阈值，越低越健康。
excellent = 40.0
good = 60.0
warning = 80.0

[code_entropy.scoring_v1.dimensions.structure.metrics.shared_bucket_ratio]
label = "共享承载目录占比"
category = "custom"
enabled = true
formula = "div(facts.shared_bucket_total, facts.total_files, 0)"
formula_cn = "shared_bucket_total / total_files"
meaning_cn = "把人工配置的共享承载目录唯一文件总量，占全部 Java 文件的比例作为结构膨胀信号，避免 common/util 别名重叠时重复计数。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.max_dir_files_ratio]
label = "最大目录文件占比"
category = "general"
enabled = true
formula = "div(facts.max_dir_files, facts.total_files, 0)"
formula_cn = "max_dir_files / total_files"
meaning_cn = "避免直接用最大目录绝对文件数，改为看单目录吞掉全仓库文件的比例。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.oversized_dir_ratio]
label = "超大目录数量占比"
category = "general"
enabled = true
formula = "div(facts.oversized_dir_count, facts.total_dirs, 0)"
formula_cn = "oversized_dir_count / total_dirs"
meaning_cn = "超过超大目录阈值的目录数量，占全部目录的比例；用来识别不是单点，而是多处目录同时膨胀。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.top_n_dir_concentration]
label = "前 N 大目录集中度"
category = "general"
enabled = true
formula = "div(facts.top_n_dir_file_sum, facts.total_files, 0)"
formula_cn = "top_n_dir_file_sum / total_files"
meaning_cn = "把前 N 大目录合计吞掉的文件量，占全部文件的比例；用来识别代码是否被少数目录长期垄断。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.avg_files_per_dir]
label = "平均目录文件数"
category = "general"
enabled = true
formula = "div(facts.total_files, facts.total_dirs, 0)"
formula_cn = "total_files / total_dirs"
meaning_cn = "目录平均承载量，反映目录粒度是否长期失衡。"
unit = "files_per_dir"
round_digits = 2
when_missing = "zero"

